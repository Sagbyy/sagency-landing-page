---
import Button from "../ui/Button.astro";
import headerVideoDesktop from "../../assets/hero/header-desktop.mp4";
import headerVideoMobile from "../../assets/hero/header-mobile.mp4";
import headerImage from "../../assets/hero/hero-card-bg.png";
---

<section
  class="relative h-screen min-h-screen overflow-hidden pt-10 pb-10 md:pt-36 md:pb-24"
>
  <video
    id="hero-video"
    autoplay
    muted
    loop
    playsinline
    class="absolute inset-0 h-full w-full object-cover"
    aria-hidden="true"
    data-mobile-src={headerVideoMobile}
    data-desktop-src={headerVideoDesktop}></video>
  <div
    class="container mx-auto flex h-full flex-col items-center justify-center px-7 md:block md:px-0"
  >
    <div
      id="hero-card"
      class="relative z-10 flex h-fit w-full flex-col justify-center gap-5 rounded-3xl p-6 py-12 text-center text-white md:h-full md:w-[550px] md:p-16 md:py-24 md:text-left"
      style={{
        backgroundImage: `url(${headerImage.src})`,
        backgroundPosition: "30%",
        backgroundSize: "cover",
        backgroundRepeat: "no-repeat",
      }}
    >
      <p
        class="hero-anim text-center text-lg font-light uppercase md:text-left md:text-xl"
      >
        Sagency
      </p>
      <h1
        class="hero-anim font-urbanist text-center text-4xl font-normal md:text-left md:text-5xl"
      >
        Votre partenaire technologique pour développer vos solutions.
      </h1>
      <p class="hero-anim text-center text-sm md:text-left md:text-base">
        Une idée de produit ? Nous vous accompagnons pour la transformer en
        réalité
      </p>
      <div class="hero-anim hidden text-center md:block md:text-left">
        <Button href="#contact" text="Commencer votre projet" color="white" />
      </div>
    </div>
    <div
      class="hero-anim mt-auto block w-full text-center md:hidden md:w-auto md:text-left"
    >
      <Button
        href="#contact"
        text="Commencer votre projet"
        color="black"
        className="w-full"
      />
    </div>
  </div>
</section>

<style>
  .hero-anim {
    opacity: 0;
  }
</style>

<script>
  import gsap from "gsap";

  // Charge uniquement la vidéo adaptée à la résolution courante
  const video = document.getElementById(
    "hero-video",
  ) as HTMLVideoElement | null;
  if (video) {
    const src = window.matchMedia("(min-width: 768px)").matches
      ? video.dataset.desktopSrc
      : video.dataset.mobileSrc;
    if (src) {
      video.src = src;
      video.load();
    }
  }

  function initHeroAnimations() {
    const items = document.querySelectorAll(".hero-anim");
    if (!items.length) return;

    gsap.fromTo(
      items,
      { opacity: 0, y: 32 },
      {
        opacity: 1,
        y: 0,
        duration: 0.7,
        stagger: 0.12,
        ease: "power3.out",
        delay: 0.2,
      },
    );
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHeroAnimations);
  } else {
    initHeroAnimations();
  }
</script>
