---
import background from "../../assets/projects/background.png";
import vendingMachine from "../../assets/projects/vending-machine.avif";
import electricBox from "../../assets/projects/saas-electrician.jpg";
import hotelReservation from "../../assets/projects/airbnb.png";
import flightPricePrediction from "../../assets/projects/ai-flight.jpg";
import networkRefurbishment from "../../assets/projects/network.jpg";
import crimeLab from "../../assets/projects/crime-lab.png";
import socialNetwork from "../../assets/projects/social-network.png";
import securityAudit from "../../assets/projects/audit-cyber.jpg";
import backOffice from "../../assets/projects/back-office-software.png";

const projects = [
  {
    title: "Logiciel distributeur automatique",
    description:
      "Application embarquée pour piloter et monitorer des distributeurs automatiques connectés en temps réel.",
    category: "Objets Connectés",
    sector: "IoT",
    tags: ["Kotlin", "Jetpack Compose", "Java"],
    image: vendingMachine,
  },
  {
    title: "Gestion d'activités électriciens",
    description:
      "Plateforme SaaS permettant aux électriciens de gérer leurs chantiers et les manager des devis et factures depuis un dashboard.",
    category: "Application Web",
    sector: "PropTech",
    tags: ["React", "NestJS", "PostgreSQL", "Prisma"],
    image: electricBox,
  },
  {
    title: "Application d'analyse de relations utilisateurs",
    description:
      "Application permettant d'analyser les relations utilisateurs avec un graphique de toutes les relations.",
    category: "Application Web",
    sector: "Cybersécurité",
    tags: ["React", "Neo4j"],
    image: crimeLab,
  },
  {
    title: "Réseau social",
    description:
      "Réseau social permettant de partager des photos et des vidéos avec des amis qui s'inspire de Twitter.",
    category: "Application Web",
    sector: "Social Media",
    tags: ["React", "Tailwind CSS", "shadcn/ui"],
    image: socialNetwork,
  },
  {
    title: "Plateforme de réservation d'hébergements",
    description:
      "Marketplace de réservation d'hébergements pour des particuliers au style d'Airbnb",
    category: "Application Mobile",
    sector: "Travel Tech",
    tags: ["Kotlin", "Jetpack Compose", "Java"],
    image: hotelReservation,
  },
  {
    title: "Audit cybersécurité",
    description:
      "Audit cybersécurité d'une entreprise avec plusieurs millions de données pour trouver les vulnérabilités et des corriger.",
    category: "Cybersécurité",
    sector: "Publishing Tech",
    tags: ["Nmap", "ffuf", "Wireshark"],
    image: securityAudit,
  },
  {
    title: "Prédiction de prix de vols avec IA",
    description:
      "Entrainement d'un modèle IA permettant de prédire les prix de vols en fonction de différents critères.",
    category: "IA",
    sector: "Travel Tech",
    tags: ["Python", "Machine Learning", "Data Science"],
    image: flightPricePrediction,
  },
  {
    title: "Refonte d’infrastructure réseau et déploiement applicatif",
    description:
      "Déploiement de ses applications sur une nouvelle infrastructure serveur afin d’améliorer la performance et la sécurité.",
    category: "Système & Réseaux",
    sector: "IT",
    tags: ["Linux", "Nginx", "VLAN"],
    image: networkRefurbishment,
  },
  {
    title: "Back-office",
    description:
      "Développement d'un back-office complet pour gérer toutes les ressources d'une application web publique.",
    category: "Application Web",
    sector: "IT",
    tags: ["Vue.js", "Laravel"],
    image: backOffice,
  },
];
---

<section
  id="projects"
  class="overflow-hidden py-20 md:py-28"
  style={{
    backgroundImage: `url(${background.src})`,
    backgroundSize: "cover",
    backgroundPosition: "center",
    backgroundRepeat: "no-repeat",
  }}
>
  <div class="container mx-auto mb-12 px-7 md:mb-16 md:px-0">
    <div class="mx-auto flex max-w-3xl flex-col gap-4 text-center">
      <p class="projects-anim text-xl text-white">04</p>
      <p
        class="projects-anim text-lg font-extralight tracking-[25%] text-white uppercase lg:text-xl"
      >
        [NOS PROJETS]
      </p>
      <h2
        class="projects-anim font-urbanist text-4xl leading-tight font-medium text-white lg:text-5xl"
      >
        Voici les projets que nous avons réalisés
      </h2>
    </div>
  </div>

  <div
    id="projects-carousel"
    class="projects-carousel-anim relative cursor-grab active:cursor-grabbing"
  >
    <div id="projects-track" class="flex gap-5" style="width: max-content">
      {
        [...projects, ...projects].map((project) => (
          <article
            class="project-card relative flex h-[460px] w-[320px] shrink-0 flex-col justify-between overflow-hidden rounded-2xl p-6 md:h-[600px] md:w-[380px] md:p-8"
            style={`background-image: url(${project.image.src}); background-size: cover; background-position: center;`}
          >
            <div class="absolute inset-0 bg-black/50" aria-hidden="true" />

            <div class="relative z-10 flex items-start justify-between">
              <span class="text-sm font-light text-white/70">
                {project.sector}
              </span>
              <span class="rounded-full border border-white/30 bg-white/10 px-3 py-1 text-xs tracking-widest text-white/80 uppercase backdrop-blur-sm">
                {project.category}
              </span>
            </div>
            <div class="relative z-10 flex flex-col gap-3">
              <h3 class="font-urbanist text-xl leading-tight font-semibold text-white md:text-2xl">
                {project.title}
              </h3>
              {project.description && (
                <p class="text-sm leading-relaxed text-white/90">
                  {project.description}
                </p>
              )}
              <div class="flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class="rounded-full bg-white/15 px-2.5 py-1 text-xs text-white/80 backdrop-blur-sm">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects-anim,
  .projects-carousel-anim {
    opacity: 0;
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { Observer } from "gsap/Observer";

  gsap.registerPlugin(ScrollTrigger, Observer);

  function initProjectsAnimations() {
    const section = document.getElementById("projects");
    if (!section) return;

    gsap.fromTo(
      section.querySelectorAll(".projects-anim"),
      { opacity: 0, y: 40 },
      {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.1,
        ease: "power3.out",
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          toggleActions: "play none none none",
        },
      },
    );

    gsap.fromTo(
      "#projects-carousel",
      { opacity: 0, y: 60 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: "power3.out",
        scrollTrigger: {
          trigger: "#projects-carousel",
          start: "top 85%",
          toggleActions: "play none none none",
        },
      },
    );

    const track = document.getElementById("projects-track");
    if (!track) return;

    const totalWidth = track.scrollWidth / 2;
    const isMobile = window.matchMedia("(max-width: 767px)").matches;

    let currentX = 0;
    let speed = isMobile ? 0.4 : 1;
    let isDragging = false;
    let lastPointerX = 0;

    gsap.ticker.add(() => {
      if (!isDragging) {
        currentX -= speed;
        if (currentX <= -totalWidth) currentX += totalWidth;
        if (currentX > 0) currentX -= totalWidth;
      }
      gsap.set(track, { x: currentX });
    });

    track.addEventListener("mouseenter", () => {
      speed = 0.2;
    });
    track.addEventListener("mouseleave", () => {
      if (!isDragging) speed = isMobile ? 0.4 : 1;
    });

    Observer.create({
      target: track,
      type: "pointer",
      onPress: (self) => {
        isDragging = true;
        lastPointerX = self.x ?? 0;
      },
      onDrag: (self) => {
        const x = self.x ?? lastPointerX;
        currentX += x - lastPointerX;
        lastPointerX = x;
        if (currentX <= -totalWidth) currentX += totalWidth;
        if (currentX > 0) currentX -= totalWidth;
      },
      onRelease: () => {
        isDragging = false;
        speed = isMobile ? 0.4 : 1;
      },
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initProjectsAnimations);
  } else {
    initProjectsAnimations();
  }
</script>
