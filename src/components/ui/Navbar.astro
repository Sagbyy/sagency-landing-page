---
import sagencyLogo from "../../assets/sagency-logo.png";
import { Icon } from "astro-icon/components";
import Button from "./Button.astro";
---

<nav
  id="navbar"
  class="fixed top-0 right-4 left-0 z-50 mx-auto mt-6 max-w-7xl px-4 md:right-0 md:px-7 lg:px-0"
>
  <div class="flex items-center justify-between">
    <div class="nav-anim flex w-full justify-end md:hidden">
      <button
        type="button"
        id="burger-btn"
        class="cursor-pointer rounded-full border border-neutral-400 bg-black p-2.5 transition-colors hover:bg-neutral-900"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon id="burger-icon" name="ri:menu-line" class="h-6 w-6 text-white" />
      </button>
    </div>

    <div class="nav-anim hidden w-full items-center justify-between md:flex">
      <div class="rounded-full border border-neutral-200 bg-white px-5">
        <ul class="flex gap-6">
          <li class="flex items-center justify-center">
            <a href="/">
              <img src={sagencyLogo.src} alt="Logo" class="h-7 w-auto" />
            </a>
          </li>
          <li class="my-5">
            <a href="#about">À propos</a>
          </li>
          <li class="my-5">
            <a href="#services">Services</a>
          </li>
          <li class="my-5">
            <a href="#process">Processus</a>
          </li>
          <li class="my-5">
            <a href="#projects">Projets</a>
          </li>
          <li class="my-5">
            <a href="#faq">FAQ</a>
          </li>
          <li class="my-5">
            <a href="#contact">Contact</a>
          </li>
        </ul>
      </div>
      <div class="rounded-full border border-neutral-200 bg-white">
        <ul class="flex items-center justify-center gap-3 p-2 pl-4">
          <li class="flex items-center justify-center">
            <a
              href="https://x.com/sagencytech"
              target="_blank"
              class="inline-flex items-center justify-center gap-1.5"
            >
              <Icon name="ri:twitter-x-line" />
              <Icon name="iconamoon:arrow-top-right-1" />
            </a>
          </li>
          <li>
            <Button href="#contact" text="Réserver un appel" color="black" />
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="pointer-events-none fixed inset-0 z-40 border border-neutral-200 bg-white px-6 pt-8 pb-8 opacity-0 transition-opacity duration-200 data-open:pointer-events-auto data-open:opacity-100 md:hidden"
    aria-hidden="true"
  >
    <div class="mb-12 flex items-center justify-between">
      <a href="/" class="">
        <img src={sagencyLogo.src} alt="Logo" class="h-7 w-auto" />
      </a>
      <button
        type="button"
        id="mobile-menu-close"
        class="rounded-full p-2 transition-colors hover:bg-neutral-100"
        aria-label="Fermer le menu"
      >
        <Icon name="ri:close-line" class="h-7 w-7" />
      </button>
    </div>
    <ul class="flex flex-col gap-6 text-lg">
      <li><a href="#about" class="nav-mobile-link block py-2">À propos</a></li>
      <li>
        <a href="#services" class="nav-mobile-link block py-2">Services</a>
      </li>
      <li>
        <a href="#process" class="nav-mobile-link block py-2">Processus</a>
      </li>
      <li>
        <a href="#projects" class="nav-mobile-link block py-2">Projets</a>
      </li>
      <li>
        <a href="#faq" class="nav-mobile-link block py-2">FAQ</a>
      </li>
      <li><a href="#contact" class="nav-mobile-link block py-2">Contact</a></li>
    </ul>
    <div class="mt-8 border-t border-neutral-200 pt-8">
      <a
        href="https://x.com/sagencytech"
        target="_blank"
        class="nav-mobile-link inline-flex items-center gap-2 py-2"
      >
        <Icon name="ri:twitter-x-line" class="h-5 w-5" />
        <Icon name="iconamoon:arrow-top-right-1" class="h-4 w-4" />
      </a>
      <div class="mt-4">
        <Button
          href="#contact"
          text="Réserver un appel"
          color="black"
          className="nav-mobile-link"
        />
      </div>
    </div>
  </div>
</nav>

<script>
  import gsap from "gsap";

  function initNavAnimations() {
    const items = document.querySelectorAll(".nav-anim");
    if (!items.length) return;

    gsap.fromTo(
      items,
      { opacity: 0, y: -16 },
      {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power3.out",
        delay: 0.15,
      },
    );
  }

  function initMobileMenu() {
    const btn = document.getElementById("burger-btn");
    const menu = document.getElementById("mobile-menu");
    const closeBtn = document.getElementById("mobile-menu-close");

    if (!btn || !menu) return;

    function closeMenu() {
      if (!menu || !btn) return;
      menu.removeAttribute("data-open");
      menu.setAttribute("aria-hidden", "true");
      btn.setAttribute("aria-expanded", "false");
      btn.setAttribute("aria-label", "Ouvrir le menu");
      document.body.style.overflow = "";
    }

    function openMenu() {
      if (!menu || !btn) return;
      menu.setAttribute("data-open", "");
      menu.removeAttribute("aria-hidden");
      btn.setAttribute("aria-expanded", "true");
      btn.setAttribute("aria-label", "Fermer le menu");
      document.body.style.overflow = "hidden";
    }

    btn.addEventListener("click", () => {
      const isOpen = menu.hasAttribute("data-open");
      if (isOpen) closeMenu();
      else openMenu();
    });

    closeBtn?.addEventListener("click", closeMenu);

    menu.querySelectorAll(".nav-mobile-link").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      initNavAnimations();
      initMobileMenu();
    });
  } else {
    initNavAnimations();
    initMobileMenu();
  }
</script>
